{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "play",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/c",
                "for /f %a in (\"%cd%\") do set projectName=%~nxa && echo Building %~nxa && make -j14 && echo. && echo Launching %~nxa && \"C:\\Program Files\\mGBA\\mGBA.exe\" -f \"%cd%\\%~nxa.gba\""
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
	{
		"label": "compile",
		"type": "shell",
		"command": "cmd.exe",
		"args": [
			"/c",
			"make -j14 && @echo off && color 0A && echo Finished compiling assets"
		],
		"group": 
		{
			"kind": "build",
			"isDefault": false
		},
		"presentation": {
			"echo": true,
			"reveal": "always",
			"focus": false,
			"panel": "shared",
			"showReuseMessage": true,
			"clear": false
		}
	}
    ]
}
